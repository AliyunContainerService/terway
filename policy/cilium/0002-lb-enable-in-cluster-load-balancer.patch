index fcaafc7241..86f6655209 100644
--- a/pkg/client/client.go
+++ b/pkg/client/client.go
@@ -690,6 +690,9 @@ func FormatStatusResponse(w io.Writer, sr *models.StatusResponse, sd StatusDetai
