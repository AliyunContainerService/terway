index 0000000000..9e4cbe8fa5
--- /dev/null
+++ b/daemon/cmd/hoststack-cidr.go
@@ -0,0 +1,48 @@
+package cmd
+
+import (
+	"fmt"
+	"log/slog"
+	"net/netip"
+
+	"github.com/cilium/cilium/pkg/maps/hoststackcidr"
+	"github.com/cilium/cilium/pkg/option"
+)
+
+func initHostStackCIDR(logger *slog.Logger) error {
+	if err := hoststackcidr.HostStackCIDRMap(nil).OpenOrCreate(); err != nil {
+		return fmt.Errorf("failed to create host stack CIDR map: %w", err)
+	}
+
+	exists, err := hoststackcidr.DumpToMap()
+	if err != nil {
+		return fmt.Errorf("failed to dump host stack CIDR map: %w", err)
+	}
+
+	for prefix := range exists {
+		logger.Debug("host stack CIDR entry", "prefix", prefix)
+	}
+
+	for _, cidr := range option.Config.HostStackCIDRs {
+		expect, err := netip.ParsePrefix(cidr)
+		if err != nil {
+			logger.Debug("parse cidr error, ignored", "error", err)
+		} else {
+			err = hoststackcidr.AddCIDREntry(expect, 0)
+			if err != nil {
+				logger.Error("Failed to add default host stack CIDR entry", "error", err)
+			} else {
+				delete(exists, expect)
+			}
+		}
+	}
+
+	for prefix := range exists {
+		err = hoststackcidr.DeleteCIDREntry(prefix)
+		if err != nil {
+			logger.Warn("Failed to delete default host stack CIDR entry", "error", err)
+		}
+	}
+
+	return nil
+}
